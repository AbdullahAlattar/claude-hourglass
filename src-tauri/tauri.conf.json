{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Hourglass",
  "version": "0.1.4",
  "identifier": "com.alattar.claudehourglass",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Claude Hourglass",
        "width": 480,
        "height": 180,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "shadow": false,
        "focus": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "_comment": "Ad-hoc signing (signingIdentity '-') applies a valid but un-trusted signature. arm64 macOS rejects unsigned binaries as 'damaged'; ad-hoc downgrades that to the standard 'unidentified developer' Gatekeeper warning, which the user can bypass via right-click → Open (Sonoma) or System Settings → Privacy & Security → Open Anyway (Sequoia).",
      "signingIdentity": "-"
    }
  }
}
